{
  "id": "waystar-playwright-flow",
  "name": "Waystar Claims Flow",
  "version": "1.0.0",
  "description": "Converted from Playwright sample to flow format",
  "config": {
    "baseUrl": "https://login.zirmed.com",
    "timeout": 30000,
    "retries": 1,
    "headless": false,
    "viewport": {
      "width": 1280,
      "height": 720
    },
    "video": false
  },
  "variables": {
    "loginName": "TanMoative",
    "password": "Rcs@moative46483"
  },
  "steps": [
    {
      "id": "step-1",
      "action": "navigate",
      "description": "Open Waystar login page",
      "url": "{{baseUrl}}/UI/Login",
      "waitUntil": "load"
    },
    {
      "id": "step-2",
      "action": "fill",
      "description": "Enter login name",
      "selector": "#loginName",
      "value": "{{loginName}}",
      "clearFirst": true
    },
    {
      "id": "step-3",
      "action": "fill",
      "description": "Enter password",
      "selector": "#password",
      "value": "{{password}}",
      "clearFirst": true
    },
    {
      "id": "step-4",
      "action": "click",
      "description": "Click Log in",
      "selector": "role=button[name='Log in']"
    },
    {
      "id": "step-5",
      "action": "navigate",
      "description": "Open Claims page directly",
      "url": "https://claims.zirmed.com/Claims/Listing/Index?appid=1",
      "waitUntil": "load"
    },
    {
      "id": "step-6",
      "action": "waitForTimeout",
      "description": "Wait 3 seconds after opening Claims page",
      "ms": 3000
    },
    {
      "id": "step-7",
      "action": "selectOption",
      "description": "Set claim status to all",
      "selector": "#SearchCriteria_Status",
      "value": "-1"
    },
    {
      "id": "step-8",
      "action": "waitForTimeout",
      "description": "Wait 3 seconds after setting claim status",
      "ms": 3000
    },
    {
      "id": "step-9",
      "action": "selectOption",
      "description": "Set transaction date range to two years",
      "selector": "#SearchCriteria_TransDate",
      "value": "2 years"
    },
    {
      "id": "step-10",
      "action": "waitForTimeout",
      "description": "Wait 3 seconds after setting transaction date",
      "ms": 3000
    },
    {
      "id": "step-11",
      "action": "click",
      "description": "Run claim search",
      "selector": "#ClaimListingSearchButtonBottom"
    },
    {
      "id": "step-10",
      "action": "waitForTimeout",
      "description": "Wait 3 seconds after setting transaction date",
      "ms": 9000
    }
  ],
  "teardown": []
}
